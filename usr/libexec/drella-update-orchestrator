#!/usr/bin/env bash
set -euo pipefail

REPO_URL="https://github.com/drellabot/orchestrator.git"
REPO_DIR="${HOME}/orchestrator"

CHANGED=0

if [ ! -d "${REPO_DIR}" ]; then
    git clone "${REPO_URL}" "${REPO_DIR}"
    CHANGED=1
else
    HEAD_BEFORE=$(git -C "${REPO_DIR}" rev-parse HEAD)
    git -C "${REPO_DIR}" pull --ff-only
    HEAD_AFTER=$(git -C "${REPO_DIR}" rev-parse HEAD)

    if [ "${HEAD_BEFORE}" != "${HEAD_AFTER}" ]; then
        echo "Orchestrator updated (${HEAD_BEFORE::8} -> ${HEAD_AFTER::8})"
        CHANGED=1
    else
        echo "Orchestrator already up to date (${HEAD_AFTER::8})"
    fi
fi

if [ "${CHANGED}" = "1" ]; then
    echo "Building orchestrator"
    (cd "${REPO_DIR}" && go build -o orchestrator ./cmd/orchestrator)

    echo "Installing gjoll"
    go install github.com/ondrejbudai/gjoll/cmd/gjoll@latest

    if [ ! -f "${REPO_DIR}/Caddyfile" ]; then
        cp "${REPO_DIR}/Caddyfile.example" "${REPO_DIR}/Caddyfile"
    fi

    systemctl --user enable orchestrator.service dashboard.service
    echo "Restarting orchestrator and dashboard"
    systemctl --user restart orchestrator.service dashboard.service
fi
