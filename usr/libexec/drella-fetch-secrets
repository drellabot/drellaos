#!/usr/bin/env bash
set -euo pipefail

# Detect if running in AWS by checking for the metadata service
# In local deployments (VM or container), this will not be available
if ! curl -s --connect-timeout 1 http://169.254.169.254/latest/meta-data/ >/dev/null 2>&1; then
    echo "Not running in AWS environment, skipping credential fetch from AWS Secrets Manager"
    echo "For local deployments, credentials should be configured manually or via other means"
    exit 0
fi

echo "Running in AWS environment, fetching credentials from Secrets Manager"

SECRET_NAME="drella-secrets"
AWS_REGION="us-east-1"
HOME_DIR="/var/home/drella"

SECRET_JSON=$(aws secretsmanager get-secret-value \
    --region "${AWS_REGION}" \
    --secret-id "${SECRET_NAME}" \
    --query SecretString \
    --output text)

# GCloud application default credentials
GCLOUD_DIR="${HOME_DIR}/.config/gcloud"
GCLOUD_FILE="${GCLOUD_DIR}/application_default_credentials.json"
install -d -o drella -g drella -m 0700 "${GCLOUD_DIR}"
echo "${SECRET_JSON}" | jq -r '.gcloud_credentials' > "${GCLOUD_FILE}"
chown drella:drella "${GCLOUD_FILE}"
chmod 0600 "${GCLOUD_FILE}"

# GitHub CLI auth token
echo "${SECRET_JSON}" | jq -r '.gh_token' | sudo --set-home --user=drella gh auth login --with-token --git-protocol https
